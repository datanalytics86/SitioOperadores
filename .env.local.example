# ─────────────────────────────────────────────
# OperadoresFaena.cl — Variables de entorno
# Copia este archivo como .env.local y completa los valores reales.
# NUNCA commitees .env.local al repositorio.
# ─────────────────────────────────────────────

# Bolt Database / Supabase
# Encuéntralas en: supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...replace-me

# ADVERTENCIA: La service_role key tiene acceso total sin RLS.
# Solo usar en server-side / edge functions. NUNCA exponer al cliente.
# SUPABASE_SERVICE_ROLE_KEY=ojo-secreto-no-commitear
